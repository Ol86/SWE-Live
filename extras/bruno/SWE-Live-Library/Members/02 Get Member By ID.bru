meta {
  name: 02 Get Member By ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/rest/members/1
  body: none
  auth: none
}

tests {
  test("returns HTTP 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("returns the requested member", function() {
    expect(res.body).to.have.property("id");
    expect(res.body.id).to.equal(Number(bru.getEnvVar("memberId")));
  });
}
